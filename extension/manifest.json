{
    "manifest_version": 3,
    "name": "LeetViz",
    "version": "1.0.0",
    "description": "Interactive visualizers for LeetCode problems — powered by the community.",
    "permissions": [
        "activeTab",
        "tabs",
        "sidePanel",
        "storage"
    ],

    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://leetcode.com/problems/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {

        "default_title": "Open LeetViz"
    },
    "host_permissions": [
        "https://vinayak-sutar.github.io/*",
        "http://localhost:8190/*"
    ]
}